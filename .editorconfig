root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[*.go]
indent_style = tab

[*.sql]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.lua]
indent_style = space
indent_size = 2

space_around_concat_operator = false
table_separator_style = only_kv_colon
end_statement_with_semicolon = same_line
trailing_table_separator = smart

[*.nix]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{js,ts,json,code-workspace,code-snippets}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.css]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[{*.sh,.envrc}]
indent_style = space
indent_size = 2
